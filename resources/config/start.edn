                          :effects.target/stun         clojure.applicable-stun/f
                          }
                         )
 (clojure.add-methods/f! clojure.is-useful/f
                         {
                          :default               clojure.useful-default/f

                          :effects/audiovisual   clojure.effects-useful-audiovisual/f
                          :effects/projectile    clojure.useful-projectile/f
