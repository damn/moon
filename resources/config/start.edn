                          :s/one-to-one  clojure.create-value-one-to-one/f
                          }
                         )
 (clojure.add-methods/f! clojure.create-entity-state/f
                         {
                          :default               clojure.create-default/f

                          :active-skill          clojure.create-active-skill/f
