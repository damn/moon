                          :player-item-on-cursor clojure.draw-ui-view-player-item-on-cursor/f
                          }
                         )
 (clojure.add-methods/f! clojure.is-applicable/f
                         {
                          :effects/audiovisual   clojure.effects-applicable-audiovisual/f
