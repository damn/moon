                          :effects/target-entity clojure.useful-target-entity/f

                          :effects.target/audiovisual clojure.effects-target-useful-audiovisual/f
                          }
                         )
 (clojure.add-methods/f! clojure.handle/f
                         {
                          :effects/audiovisual   clojure.effects-handle-audiovisual/f
