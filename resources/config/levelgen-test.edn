[
 (clojure.add-methods/f! clojure.malli-form/malli-form #edn/resource "config/k->malli_form.edn")
 (gdx.use-glfw-async/f!)
 (gdx.application/f!
  {:listener (gdx.listener/f
              {:state-var levelgen-test.app/state
               :create-pipeline [
                                 (create.gdx-context/f)
                                 (clojure.m.assoc-create/f :ctx/db create.db/step)
                                 (clojure.m.assoc-create/f :ctx/textures create.textures/step)
                                 (clojure.m.assoc-create/f :ctx/sprite-batch create.batch/step)
                                 (clojure.m.assoc-create/f :ctx/skin create.skin/step)
                                 (levelgen-test.create/f!)
                                 ]
               :dispose! levelgen-test.dispose/f!
               :render-pipeline [(render.clear-screen/step)
                                 (levelgen-test.render/f!)]
               :resize! levelgen-test.resize/f!})
   :title "Levelgen Test"
   :windowed-mode {:width 1440 :height 900}
   :foreground-fps 60}
  )
 ]
