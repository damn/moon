{
 :state-var game.app/state
 :create-pipeline [
                   (ctx.gdx-context/f)
                   (ctx.unorganised/step)
                   (clojure.map.assoc-create/f :ctx/batch ctx.batch/step)
                   (clojure.map.assoc-create/f :ctx/audio ctx.audio/step)
                   (clojure.map.assoc-create/f :ctx/shape-drawer-texture ctx.shape-drawer-texture/step)
                   (clojure.map.assoc-create/f :ctx/shape-drawer ctx.shape-drawer/step)
                   (clojure.map.assoc-create/f :ctx/skin ctx.skin/step)
                   (clojure.map.assoc-create/f :ctx/stage ctx.stage/step)
                   (clojure.pipeline.do/step
                    (ctx.tooltip-manager-opts/step))
                   (clojure.pipeline.do/step
                    (ctx.put-colors/step))
                   (clojure.map.assoc-create/f :ctx/cursors ctx.cursors/step)
                   (clojure.map.create/f :ctx/textures (ctx.textures/step
                                                {:folder "resources/"
                                                 :extensions #{"png" "bmp"}}))
                   (clojure.map.assoc-create/f :ctx/world-viewport ctx.world-viewport/step)
                   (clojure.map.assoc-create/f :ctx/default-font ctx.default-font/step)
                   (ctx.record/step)
                   (ctx.controls/step)
                   (clojure.map.assoc-create/f :ctx/colors ctx.colors/step)
                   (clojure.map.assoc-create/f :ctx/render-z-order ctx.render-z-order/step)
                   (clojure.map.assoc-create/f :ctx/max-speed ctx.max-speed/step)
                   (clojure.map.assoc-create/f :ctx/db ctx.db/step)
                   (clojure.pipeline.do/step
                    (ctx.add-stage-actors/f! [(stage.dev-menu/create)
                                                 (stage.action-bar/create)
                                                 (stage.hp-mana-bar/create)
                                                 (stage.windows/create [stage.info-window/create
                                                                        stage.inventory-window/create])
                                                 (stage.player-state-draw/create)
                                                 (stage.player-message-actor/create)]))
                   (ctx.tiled-map/step #edn/resource
                                          ; "config/world_fns/modules.edn"
                                          "config/world_fns/vampire.edn"
                                          ; "config/world_fns/uf_caves.edn"
                                          )
                   (clojure.map.assoc-create/f :ctx/grid ctx.grid/step)
                   (clojure.map.assoc-create/f :ctx/content-grid ctx.content-grid/step)
                   [clojure.map.assoc-create/f :ctx/explored-tile-corners ctx.explored-tile-corners/step]
                   [clojure.map.assoc-create/f :ctx/raycaster ctx.raycaster/step]
                   (ctx.spawn-player/step)
                   (clojure.pipeline.do/step
                    (ctx.spawn-enemies/step))
                   (clojure.core/dissoc :ctx/files)
                   ]
 :dispose! ctx.dispose/do!
 :render-pipeline [
                   [render.get-stage-ctx/step]
                   [render.validate/step]
                   [render.update-mouse-positions/step]
                   [render.update-mouseover-eid/step]
                   [render.check-debug-viewer/step]
                   [render.set-active-entities/step]
                   [render.set-camera-position/step]
                   [render.clear-screen/step]
                   [render.draw-tiled-map/step]
                   [render.draw-on-world-viewport/step [
                                                        #_(ctx.draw-on-world-viewport.draw-tile-grid/f)
                                                        (ctx.draw-on-world-viewport.draw-cell-debug/f)
                                                        (ctx.draw-on-world-viewport.draw-entities/do! [#{:entity/mouseover?
                                                                                                     :stunned
                                                                                                     :player-item-on-cursor}
                                                                                                   #{:entity/clickable
                                                                                                     :entity/animation
                                                                                                     :entity/image
                                                                                                     :entity/line-render}
                                                                                                   #{:npc-sleeping
                                                                                                     :entity/temp-modifier
                                                                                                     :entity/string-effect}
                                                                                                   #{:entity/stats
                                                                                                     :active-skill}]
                                                                                                  )
                                                        #_(moon.geom-test)
                                                        (ctx.draw-on-world-viewport.highlight-mouseover-tile/f)
                                                        ]]
                   (clojure.map.assoc-create/f :ctx/interaction-state render.assoc-interaction-state/create)
                   [render.set-cursor/step]
                   [render.handle-player-input/step]
                   (clojure.core/dissoc :ctx/interaction-state)
                   [render.assoc-paused/step]
                   [render.if-not-paused/step [
                                               render.if-not-paused.update-time/f
                                               render.if-not-paused.update-potential-fields/f
                                               render.if-not-paused.tick-entities/f
                                               ]]
                   [render.remove-destroyed-entities/step]
                   [render.window-camera-controls/step]
                   [render.update-draw-stage/step]
                   [render.validate/step]
                   ]
 :resize!  ctx.resize/do!
 }
