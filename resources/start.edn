[
 [clojure.multifn/add-methods! moon.schema/create [[:default moon.schema.default/create]]]
 [clojure.multifn/add-methods! moon.schema/value  [[:default moon.schema.default/value]]]
 [clojure.multifn/add-api-methods!
  {:required []
   :optional [moon.schema/create
              moon.schema/value
              moon.schemas/create-value]}
  [[moon.schema.animation         :s/animation]
   [moon.schema.boolean           :s/boolean]
   [moon.schema.enum              :s/enum]
   [moon.schema.image             :s/image]
   [moon.schema.map               :s/map]
   [moon.schema.number            :s/number]
   [moon.schema.one-to-many       :s/one-to-many]
